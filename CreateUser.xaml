<Window x:Class="MovieList.CreateUser"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MovieList"
        mc:Ignorable="d"
        Title="Create User 👤" Height="206" Width="424">
    <Grid Margin="0,0,0,0" Background="#FFA0C192">
        <Label Content="Username" HorizontalAlignment="Left" Margin="31,95,0,0" VerticalAlignment="Top" Width="120"/>
        <TextBox x:Name="txtbox_newUserName" HorizontalAlignment="Left" Margin="31,130,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="120"/>
        <Button x:Name="button_createactualuser" Content="Create User" HorizontalAlignment="Left" Margin="212,110,0,0" VerticalAlignment="Top" Height="58" Width="193" Click="button_createactualuser_click"/>
        <Label Content="Create a user.&#xD;&#xA;Movies can be added to your list through the blue 'Edit User'" HorizontalAlignment="Center" Margin="0,10,0,0" VerticalAlignment="Top" Height="47" Width="404"/>

    </Grid>
</Window>
